{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "productName": "SprocketPan",
  "mainBinaryName": "SprocketPan",
  "version": "1.3.1",
  "identifier": "com.sprocketpan.dev",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/itaifish/Sprocket-Pan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERERDM2QjQwNDdGRkRGQTkKUldTcDMvOUhRR3ZUM2NYNmJMR040c3ZFdTljZitTSHR3eXd5eWdlNmU3elpIcjY1WlpCczhrY1AK"
    }
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "SprocketPan",
        "label": "main",
        "width": 1600,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 675,
        "visible": false,
        "useHttpsScheme": true
      },
      {
        "width": 1600,
        "height": 900,
        "url": "splashscreen.html",
        "label": "splashscreen",
        "title": "SprocketPan",
        "useHttpsScheme": true
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  }
}